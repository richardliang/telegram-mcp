# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Session Management
TELEGRAM_SESSION_NAME=telegram_session
TELEGRAM_SESSION_STRING=1231231232erfdfdffd

# Remote MCP server settings
MCP_BIND_HOST=0.0.0.0
MCP_BIND_PORT=8000
MCP_PUBLIC_BASE_URL=https://telegram-mcp.example.com

# Single-user OAuth gate for Claude Desktop
MCP_AUTH_USERNAME=me
MCP_AUTH_PASSWORD=replace-this-now
MCP_AUTH_SCOPE=user

# Optional: colon-separated server-side file roots for file upload/download tools
MCP_ALLOWED_ROOTS=/srv/telegram-mcp:/tmp/telegram-mcp
